{
  "version": 1,
  "canisters": {
    "guardian_config": {
      "type": "rust",
      "candid": "src/guardian.did",
      "package": "guardian_config",
      "build": "cargo build --target wasm32-unknown-unknown --release --package guardian_config",
      "wasm": "target/wasm32-unknown-unknown/release/guardian_config.wasm"
    },
    "guardian_engine": {
      "type": "rust",
      "candid": "src/guardian_engine.did",
      "package": "guardian_engine",
      "build": "cargo build --target wasm32-unknown-unknown --release --package guardian_engine",
      "wasm": "target/wasm32-unknown-unknown/release/guardian_engine.wasm"
    }
  },
  "defaults": {
    "build": {
      "args": "",
      "packtool": ""
    }
  },
  "output_env_file": ".env",
  "networks": {
    "local": {
      "bind": "127.0.0.1:8000",
      "type": "ephemeral"
    },
    "ic": {
      "providers": ["https://icp0.io"],
      "type": "persistent"
    }
  }
}
