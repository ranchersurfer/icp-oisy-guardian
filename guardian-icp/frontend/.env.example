# Guardian ICP Frontend — Environment Configuration
# Copy this file to .env.local and fill in your values.

# ─── Network ──────────────────────────────────────────────────────────────────
# Which network to connect to: local | testnet | ic
VITE_CANISTER_NETWORK=local

# Override IC host (optional — inferred from VITE_CANISTER_NETWORK if not set)
# VITE_IC_HOST=http://127.0.0.1:4943

# ─── Canister IDs ─────────────────────────────────────────────────────────────
# JSON object with both canister IDs (recommended)
# Get these from `dfx canister id <name>` or dfx.json/.dfx/local/canister_ids.json
VITE_CANISTER_IDS={"guardian_engine":"u6s2n-gx777-77774-qaaba-cai","guardian_config":"uxrrr-q7777-77774-qaaaq-cai"}

# Alternatively, set individually:
# VITE_ENGINE_CANISTER_ID=u6s2n-gx777-77774-qaaba-cai
# VITE_CONFIG_CANISTER_ID=uxrrr-q7777-77774-qaaaq-cai

# ─── Mock Mode ────────────────────────────────────────────────────────────────
# Set to "true" to force mock data (no canister calls). Default: false.
# VITE_USE_MOCK=false
